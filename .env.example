# ── Core ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=dev-secret-change-me

# ── Postgres ────────────────────────────────────────────────────────────────
# Inside docker-compose the host is "postgres"; locally use "localhost".
DATABASE_URL=postgresql+psycopg://gatekeeper:gatekeeper@postgres:5432/gatekeeper

# ── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── LLM risk analyst ────────────────────────────────────────────────────────
# Provider: "mock" (deterministic, offline, no key needed) or "anthropic".
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_CACHE_TTL_SECONDS=86400

# ── Auth ────────────────────────────────────────────────────────────────────
# Bootstrap reviewer API key created by `scripts/seed.py` for the demo.
DEMO_REVIEWER_API_KEY=demo-ops-key-please-change

# ── Observability ───────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=gatekeeper
