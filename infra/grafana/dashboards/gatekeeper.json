{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "GateKeeper — Decisioning",
  "tags": ["gatekeeper"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Applications submitted",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "gatekeeper_applications_submitted_total", "refId": "A" }
      ]
    },
    {
      "type": "gauge",
      "title": "Review queue depth",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "gatekeeper_review_queue_depth", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Decisions per second by outcome",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(gatekeeper_decisions_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Decision latency (p50 / p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gatekeeper_decision_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gatekeeper_decision_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Decisions by outcome (total)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (outcome) (gatekeeper_decisions_total)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      }
    ]
  }
}
